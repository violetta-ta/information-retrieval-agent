APP_HOST=127.0.0.1
APP_PORT=8080
WEB_INDEX_HOST=127.0.0.1
WEB_INDEX_PORT=4005
WEB_INDEX_STORE_PATH=./data/web-index/store.json

LLAMA_CHAT_BASE_URL=http://127.0.0.1:8081
LLAMA_EMBED_BASE_URL=http://127.0.0.1:8082
LLAMA_CHAT_MODEL=Qwen2.5-7B-Instruct-Q4_K_M.gguf
LLAMA_EMBED_MODEL=embeddinggemma-300M-Q8_0.gguf
LLAMA_CTX_SIZE=8192

CHROMA_URL=http://127.0.0.1:8000
CHROMA_COLLECTION=local_docs

LOCAL_WEB_INDEX_URL=http://127.0.0.1:4005

TOOL_AUDIT_LOG=./logs/tool-calls.jsonl
MAX_LOCAL_RESULTS=6
LOCAL_CONFIDENCE_THRESHOLD=0.72
MAX_LOCAL_RETRIEVAL_PASSES=2
MAX_EVIDENCE_ITEMS=8
MAX_EVIDENCE_SNIPPET_CHARS=280
EVIDENCE_CHAR_BUDGET=3200

# Hard-disable telemetry / remote tracing

LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=
LANGCHAIN_API_KEY=
OTEL_SDK_DISABLED=true
DO_NOT_TRACK=1